' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
package "comment_db" <<Database>> #EAEDED {
    entity "app_review" as review {
        *id : serial PK
        --
        *book_id : int      -- logicalв†’book_db.app_product.id
        *customer_id : int  -- logicalв†’customer_db.app_customer.id
        *rating : int (1..5)
        comment : text
        *created_at : timestamp
        --
        UQ(book_id, customer_id)
    }
}

' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
' advisory_db  (RAG + behavior вЂ” uses pgvector extension)
' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
package "advisory_db" <<Database>> #FDEBD0 {
    entity "app_knowledgedocument" as kbdoc {
        *id : serial PK
        --
        *title : varchar(255)
        *content : text
        *source : varchar(50)  -- policy|faq|book_catalog|genre_guide
        *embedding : vector(384)
        *created_at : timestamp
        *updated_at : timestamp
        --
        HNSW idx (embedding vector_cosine_ops)
    }
    entity "app_chatsession" as session {
        *id : serial PK
        --
        *customer_id : int  -- logicalв†’customer_db.app_customer.id
        *is_active : boolean
        *created_at : timestamp
    }
    entity "app_chatmessage" as message {
        *id : serial PK
        --
        *session_id : int FKв†’app_chatsession.id (CASCADE)
        *role : varchar(10)  -- user|assistant
        *content : text
        context_used : jsonb
        *created_at : timestamp
    }
    entity "app_customerbehaviorsummary" as behavior {
        *customer_id : int PK  -- logicalв†’customer_db.app_customer.id
        --
        *total_orders : int
        *total_spent : decimal(12,2)
        *avg_order_value : decimal(10,2)
        favorite_categories : jsonb
        favorite_authors : jsonb
        avg_rating_given : decimal(3,2)
        purchase_frequency_days : float
        last_order_date : timestamp
        *segment : varchar(20)  -- new|active|loyal|at_risk|churned
        *updated_at : timestamp
    }

    session ||--o{ message : composes
}

' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
' Cross-database (logical) references вЂ” dashed lines
' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
auth_user .[#0D47A1]. customer  : "auth_user_id"
auth_user .[#0D47A1]. staff     : "auth_user_id"
auth_user .[#0D47A1]. manager   : "auth_user_id"

category  .[#0D47A1]. product   : "category_id"

customer  .[#0D47A1]. cart      : "customer_id"
customer  .[#0D47A1]. o_order   : "customer_id"
customer  .[#0D47A1]. review    : "customer_id"
customer  .[#0D47A1]. session   : "customer_id"
customer  .[#0D47A1]. behavior  : "customer_id"

product   .[#0D47A1]. cartitem  : "book_id"
product   .[#0D47A1]. o_item    : "book_id"
product   .[#0D47A1]. review    : "book_id"

o_order   .[#0D47A1]. payment   : "order_id"
o_order   .[#0D47A1]. shipment  : "order_id"

note bottom
  **Legend**
  вЂў Solid line = real database FK (within the same DB)
  вЂў Dashed line = logical reference across services
       (no physical FK; resolved via REST or events)
  вЂў PK = Primary Key, FK = Foreign Key, UQ = Unique
  вЂў <i>vector(384)</i> uses pgvector extension; index is HNSW with cosine distance.
end note

